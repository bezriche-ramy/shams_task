PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# Optional on same-origin Vercel deployments. Set it when the frontend runs on a different origin.
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
AUTH_TOKEN_SECRET=replace_with_a_long_random_secret
# Optional alternative to GOOGLE_PRIVATE_KEY
# GOOGLE_PRIVATE_KEY_BASE64=base64_encoded_private_key
